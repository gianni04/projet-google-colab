        "class HedgingSimulator:\n",
        "    \"\"\"\n",
        "    Vend 1 call européen et rehedge en delta-neutre à chaque pas.\n",
        "    Décomposition du PnL mark-to-market :\n",
        "        option_pnl = prime_reçue - valeur_option_courante        (position short)\n",
        "        hedge_pnl  = (cash + shares*S) - prime_reçue             (réplication)\n",
        "        net_pnl    = option_pnl + hedge_pnl   (erreur de hedge discret = gamma)\n",
        "    Mettre sigma_real > sigma_implied => le vendeur short-gamma perd (saignement).\n",
        "    \"\"\"\n",
        "    def __init__(self, engine, S0=100.0, K=100.0, T=1.0,\n",
        "                 sigma_implied=0.20, sigma_real=None, mu=0.07, n_days=252):\n",
        "        self.eng, self.S0, self.K, self.T = engine, S0, K, T\n",
        "        self.sigma_imp = sigma_implied\n",
        "        self.sigma_real = sigma_real if sigma_real is not None else sigma_implied\n",
        "        self.mu, self.n_days = mu, n_days\n",
        "\n",
        "    def generate_gbm_path(self):\n",
        "        dt = self.T / self.n_days\n",
        "        z = np.random.standard_normal(self.n_days)\n",
        "        log_ret = np.concatenate(\n",
        "            ([0.0], (self.mu - 0.5 * self.sigma_real ** 2) * dt\n",
        "                    + self.sigma_real * np.sqrt(dt) * z))\n",
        "        return self.S0 * np.exp(np.cumsum(log_ret))\n",
        "\n",
        "    def run(self, path=None):\n",
        "        if path is None:\n",
        "            path = self.generate_gbm_path()\n",
        "        n, dt, r = len(path), self.T / self.n_days, self.eng.r\n",
        "        ttm = np.maximum(np.linspace(self.T, 0.0, n), 1e-12)\n",
        "\n",
        "        opt_val = self.eng.price(path, self.K, ttm, self.sigma_imp, \"call\")\n",
        "        opt_val[-1] = max(path[-1] - self.K, 0.0)\n",
        "        deltas = self.eng.delta(path, self.K, ttm, self.sigma_imp, \"call\")\n",
        "        deltas[-1] = 1.0 if path[-1] > self.K else 0.0\n",
        "\n",
        "        premium = opt_val[0]\n",
        "        shares, cash = np.zeros(n), np.zeros(n)\n",
        "        shares[0] = deltas[0]\n",
        "        cash[0] = premium - deltas[0] * path[0]        # vend le call, achète delta actions\n",
        "\n",
        "        for t in range(1, n):                          # 252 rehedges quotidiens\n",
        "            cash[t] = cash[t - 1] * np.exp(r * dt)      # financement du book\n",
        "            cash[t] -= (deltas[t] - shares[t - 1]) * path[t]\n",
        "            shares[t] = deltas[t]\n",
        "\n",
        "        hedge_pnl = (cash + shares * path) - premium\n",
        "        option_pnl = premium - opt_val\n",
        "        return {\"path\": path, \"opt_val\": opt_val, \"delta\": deltas,\n",
        "                \"hedge_pnl\": hedge_pnl, \"option_pnl\": option_pnl,\n",
        "                \"net_pnl\": hedge_pnl + option_pnl, \"premium\": premium}"
      ],
