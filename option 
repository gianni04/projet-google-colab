        "class BlackScholesEngine:\n",
        "    \"\"\"\n",
        "    Black-Scholes-Merton entièrement vectorisé.\n",
        "    Chaque méthode accepte scalaires OU arrays numpy (broadcasting) : une\n",
        "    surface entière de prix/grecques est calculée en un seul appel, sans\n",
        "    aucune boucle python. Convention : dividende continu q, sigma annualisée,\n",
        "    T en années.\n",
        "    \"\"\"\n",
        "    def __init__(self, r: float = 0.02, q: float = 0.0):\n",
        "        self.r, self.q = r, q\n",
        "\n",
        "    def _d1_d2(self, S, K, T, sigma):\n",
        "        S, K, T, sigma = map(np.asarray, (S, K, T, sigma))\n",
        "        T = np.maximum(T, 1e-12)\n",
        "        sigma = np.maximum(sigma, 1e-12)\n",
        "        vol_sqrt_t = sigma * np.sqrt(T)\n",
        "        d1 = (np.log(S / K) + (self.r - self.q + 0.5 * sigma ** 2) * T) / vol_sqrt_t\n",
        "        return d1, d1 - vol_sqrt_t\n",
        "\n",
        "    # ---- pricing --------------------------------------------------------\n",
        "    def price(self, S, K, T, sigma, option_type=\"call\"):\n",
        "        d1, d2 = self._d1_d2(S, K, T, sigma)\n",
        "        T = np.maximum(np.asarray(T), 1e-12)\n",
        "        disc_r, disc_q = np.exp(-self.r * T), np.exp(-self.q * T)\n",
        "        if option_type == \"call\":\n",
        "            return S * disc_q * norm.cdf(d1) - K * disc_r * norm.cdf(d2)\n",
        "        elif option_type == \"put\":\n",
        "            return K * disc_r * norm.cdf(-d2) - S * disc_q * norm.cdf(-d1)\n",
        "        raise ValueError(\"option_type must be 'call' or 'put'\")\n",
        "\n",
        "    # ---- grecques de premier ordre (vectorisées) ------------------------\n",
        "    def delta(self, S, K, T, sigma, option_type=\"call\"):\n",
        "        d1, _ = self._d1_d2(S, K, T, sigma)\n",
        "        disc_q = np.exp(-self.q * np.asarray(T))\n",
        "        return disc_q * norm.cdf(d1) if option_type == \"call\" \\\n",
        "            else disc_q * (norm.cdf(d1) - 1.0)\n",
        "\n",
        "    def gamma(self, S, K, T, sigma):\n",
        "        d1, _ = self._d1_d2(S, K, T, sigma)\n",
        "        S, T, sigma = map(np.asarray, (S, T, sigma))\n",
        "        T = np.maximum(T, 1e-12)\n",
        "        return np.exp(-self.q * T) * norm.pdf(d1) / (S * sigma * np.sqrt(T))\n",
        "\n",
        "    def vega(self, S, K, T, sigma):\n",
        "        \"\"\"Vega pour +1.00 de vol. Diviser par 100 pour +1 point de vol.\"\"\"\n",
        "        d1, _ = self._d1_d2(S, K, T, sigma)\n",
        "        S, T = np.asarray(S), np.maximum(np.asarray(T), 1e-12)\n",
        "        return S * np.exp(-self.q * T) * norm.pdf(d1) * np.sqrt(T)\n",
        "\n",
        "    def theta(self, S, K, T, sigma, option_type=\"call\"):\n",
        "        \"\"\"Theta annualisé. Diviser par 365 pour un theta calendaire.\"\"\"\n",
        "        d1, d2 = self._d1_d2(S, K, T, sigma)\n",
        "        S, K, T = np.asarray(S), np.asarray(K), np.maximum(np.asarray(T), 1e-12)\n",
        "        sigma = np.asarray(sigma)\n",
        "        disc_r, disc_q = np.exp(-self.r * T), np.exp(-self.q * T)\n",
        "        term1 = -S * disc_q * norm.pdf(d1) * sigma / (2.0 * np.sqrt(T))\n",
        "        if option_type == \"call\":\n",
        "            return (term1 - self.r * K * disc_r * norm.cdf(d2)\n",
        "                    + self.q * S * disc_q * norm.cdf(d1))\n",
        "        return (term1 + self.r * K * disc_r * norm.cdf(-d2)\n",
        "                - self.q * S * disc_q * norm.cdf(-d1))\n",
        "\n",
        "    def greeks(self, S, K, T, sigma, option_type=\"call\"):\n",
        "        return {\"price\": self.price(S, K, T, sigma, option_type),\n",
        "                \"delta\": self.delta(S, K, T, sigma, option_type),\n",
        "                \"gamma\": self.gamma(S, K, T, sigma),\n",
        "                \"vega\":  self.vega(S, K, T, sigma),\n",
        "                \"theta\": self.theta(S, K, T, sigma, option_type)}\n",
        "\n",
        "    # ---- IMPLIED VOL : Newton-Raphson vectorisé (fallback brentq) --------\n",
        "    def implied_vol(self, price, S, K, T, option_type=\"call\",\n",
        "                    tol=1e-8, max_iter=100):\n",
        "        price, S, K, T = map(lambda x: np.asarray(x, float), (price, S, K, T))\n",
        "        price, S, K, T = np.broadcast_arrays(price, S, K, T)\n",
        "        # Amorce Brenner-Subrahmanyam (ATM) pour accélérer la convergence\n",
        "        with np.errstate(all=\"ignore\"):\n",
        "            seed = np.sqrt(2.0 * np.pi / np.maximum(T, 1e-12)) * (price / S)\n",
        "        sigma = np.where(np.isfinite(seed) & (seed > 1e-3), seed, 0.2)\n",
        "\n",
        "        for _ in range(max_iter):                    # Newton vectorisé\n",
        "            diff = self.price(S, K, T, sigma, option_type) - price\n",
        "            v = self.vega(S, K, T, sigma)\n",
        "            with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n",
        "                step = np.where(v > 1e-10, diff / v, 0.0)\n",
        "            sigma = np.clip(sigma - step, 1e-6, 5.0)\n",
        "            if np.nanmax(np.abs(diff)) < tol:\n",
        "                break\n",
        "\n",
        "        # Fallback brentq robuste sur les points non convergés (vega -> 0)\n",
        "        bad = np.abs(self.price(S, K, T, sigma, option_type) - price) > 1e-4\n",
        "        if np.any(bad):\n",
        "            it = np.nditer(sigma, flags=[\"multi_index\"], op_flags=[\"readwrite\"])\n",
        "            for _ in it:\n",
        "                idx = it.multi_index\n",
        "                if not bad[idx]:\n",
        "                    continue\n",
        "                f = lambda vol, i=idx: self.price(S[i], K[i], T[i], vol,\n",
        "                                                  option_type) - price[i]\n",
        "                try:\n",
        "                    sigma[idx] = brentq(f, 1e-6, 5.0, xtol=tol, maxiter=max_iter)\n",
        "                except (ValueError, RuntimeError):\n",
        "                    sigma[idx] = np.nan\n",
        "        return sigma if sigma.shape != () else float(sigma)"
      ],
