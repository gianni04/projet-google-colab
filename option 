        "@njit(fastmath=True)   # NB: pas de cache=True -> incompatible avec les cellules\n",
        "def _crr_backward_induction(S, K, T, r, q, sigma, n_steps, is_call, is_american):\n",
        "    \"\"\"\n",
        "    Rétro-induction Cox-Ross-Rubinstein, compilée JIT par Numba.\n",
        "    is_call / is_american sont des flags int (0/1) car njit n'aime ni les\n",
        "    bool python ni les str.\n",
        "    \"\"\"\n",
        "    dt = T / n_steps\n",
        "    u = np.exp(sigma * np.sqrt(dt))\n",
        "    d = 1.0 / u\n",
        "    disc = np.exp(-r * dt)\n",
        "    p = (np.exp((r - q) * dt) - d) / (u - d)\n",
        "\n",
        "    values = np.empty(n_steps + 1)                 # payoffs terminaux\n",
        "    for i in range(n_steps + 1):\n",
        "        ST = S * (u ** (n_steps - i)) * (d ** i)\n",
        "        values[i] = max(ST - K, 0.0) if is_call == 1 else max(K - ST, 0.0)\n",
        "\n",
        "    for step in range(n_steps - 1, -1, -1):        # rétro-induction\n",
        "        for i in range(step + 1):\n",
        "            cont = disc * (p * values[i] + (1.0 - p) * values[i + 1])\n",
        "            if is_american == 1:\n",
        "                ST = S * (u ** (step - i)) * (d ** i)\n",
        "                exercise = (ST - K) if is_call == 1 else (K - ST)\n",
        "                values[i] = cont if cont > exercise else exercise\n",
        "            else:\n",
        "                values[i] = cont\n",
        "    return values[0]\n",
        "\n",
        "\n",
        "class BinomialTreeEngine:\n",
        "    \"\"\"Wrapper orienté objet autour du kernel njit CRR.\"\"\"\n",
        "    def __init__(self, r=0.02, q=0.0, n_steps=1000):\n",
        "        self.r, self.q, self.n_steps = r, q, n_steps\n",
        "\n",
        "    def price(self, S, K, T, sigma, option_type=\"call\", american=True):\n",
        "        return _crr_backward_induction(\n",
        "            float(S), float(K), float(T), self.r, self.q, float(sigma),\n",
        "            self.n_steps, 1 if option_type == \"call\" else 0,\n",
        "            1 if american else 0)"
      ],
