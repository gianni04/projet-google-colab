        "# 4) Preuve d'optimisation : njit vs python pur (résultat identique)\n",
        "import time\n",
        "def _crr_py(S,K,T,r,q,sigma,n,is_call,is_am):\n",
        "    dt=T/n; u=np.exp(sigma*np.sqrt(dt)); d=1/u; disc=np.exp(-r*dt)\n",
        "    p=(np.exp((r-q)*dt)-d)/(u-d); v=[0.]*(n+1)\n",
        "    for i in range(n+1):\n",
        "        ST=S*u**(n-i)*d**i; v[i]=max(ST-K,0.) if is_call else max(K-ST,0.)\n",
        "    for s in range(n-1,-1,-1):\n",
        "        for i in range(s+1):\n",
        "            c=disc*(p*v[i]+(1-p)*v[i+1])\n",
        "            if is_am:\n",
        "                ST=S*u**(s-i)*d**i; e=(ST-K) if is_call else (K-ST); v[i]=max(c,e)\n",
        "            else: v[i]=c\n",
        "    return v[0]\n",
