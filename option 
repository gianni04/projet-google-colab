        "def plot_vol_surface(engine, S0=100.0):\n",
        "    \"\"\"Construit un smile + term structure synthétiques, les price, puis\n",
        "    INVERSE via le solveur IV et trace la surface RECONSTRUITE (round-trip).\"\"\"\n",
        "    strikes = np.linspace(70, 130, 40)\n",
        "    maturities = np.linspace(0.05, 2.0, 40)\n",
        "    KK, TT = np.meshgrid(strikes, maturities)\n",
        "    moneyness = np.log(KK / S0)\n",
        "    true_iv = np.clip(0.18 + 0.6 * moneyness ** 2          # smile en strike\n",
        "                      + 0.03 * np.exp(-TT) - 0.02 * TT, 0.05, None)  # term structure\n",
        "    prices = engine.price(S0, KK, TT, true_iv, \"call\")\n",
        "    recovered_iv = engine.implied_vol(prices, S0, KK, TT, \"call\")\n",
        "\n",
        "    fig = go.Figure(go.Surface(\n",
        "        x=strikes, y=maturities, z=recovered_iv, colorscale=\"Viridis\",\n",
        "        colorbar=dict(title=\"IV\"),\n",
        "        contours={\"z\": {\"show\": True, \"usecolormap\": True, \"project_z\": True}}))\n",
        "    fig.update_layout(\n",
        "        title=\"Surface de Volatilité Implicite (reconstruite par Newton-Raphson)\",\n",
        "        scene=dict(xaxis_title=\"Strike\", yaxis_title=\"Maturité (ans)\",\n",
        "                   zaxis_title=\"Vol implicite\"),\n",
        "        template=\"plotly_dark\", height=650)\n",
        "    return fig, float(np.nanmax(np.abs(recovered_iv - true_iv)))\n",
